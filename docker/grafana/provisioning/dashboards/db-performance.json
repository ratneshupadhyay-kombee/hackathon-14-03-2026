{
  "id": null,
  "uid": "laravel-db-performance",
  "title": "Laravel - Database Performance",
  "tags": ["laravel", "database", "mysql"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 5,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Avg DB Query Duration (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "avg_over_time({job=\"laravel_app\"} | json | __error__ = \"\" | db_execution_time_ms != \"\" | unwrap db_execution_time_ms [1m])",
          "legendFormat": "Avg Query Duration (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Response Time (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(laravel_http_response_time_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "P95 {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      }
    },
    {
      "id": 3,
      "title": "Slow Queries Log Stream (> 100ms)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | __error__ = \"\" | db_execution_time_ms > 100",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "prettifyLogMessage": true, "enableLogDetails": true }
    },
    {
      "id": 4,
      "title": "DB Error Count (last 5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"laravel_app\"} | json | __error__ = \"\" | message =~ \"SQLSTATE|QueryException|PDOException|DB QueryException\" [5m]))",
          "legendFormat": "DB Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "id": 5,
      "title": "Total HTTP Requests (last 5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(laravel_http_requests_total[5m]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 6,
      "title": "N+1 Query Test — Observability Endpoint Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(laravel_http_response_time_seconds_sum{endpoint=~\"test-observability.*\"}[5m])) / sum by (endpoint) (rate(laravel_http_response_time_seconds_count{endpoint=~\"test-observability.*\"}[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 7,
      "title": "DB Error Log Stream",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | __error__ = \"\" | message =~ \"SQLSTATE|QueryException|PDOException|DB QueryException\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true }
    }
  ]
}

{
  "id": null,
  "uid": "laravel-db-performance",
  "title": "Laravel - Database Performance",
  "tags": ["laravel", "database", "mysql"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Average DB Query Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "avg_over_time({job=\"laravel_app\"} | json | unwrap db_execution_time_ms [1m])",
          "legendFormat": "Avg Query Duration (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Max Query Duration (Spike Detection)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "max_over_time({job=\"laravel_app\"} | json | unwrap db_execution_time_ms [1m])",
          "legendFormat": "Max Query Duration (ms)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 3,
      "title": "Slow Queries (> 500ms)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | db_execution_time_ms >= 500",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true
      }
    },
    {
      "id": 4,
      "title": "Database Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"laravel_app\"} | json | message =~ \".*SQLSTATE.*|.*QueryException.*\" [5m]))",
          "legendFormat": "DB Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Total DB Queries",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"laravel_app\"} | json | db_system != \"\" [5m]))",
          "legendFormat": "Queries",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 6,
      "title": "DB Error Log Stream",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | message =~ \".*SQLSTATE.*|.*QueryException.*|.*PDOException.*\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true
      }
    }
  ]
}

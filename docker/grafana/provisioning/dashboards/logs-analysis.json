{
  "id": null,
  "uid": "laravel-logs-analysis",
  "title": "Laravel - Logs Analysis",
  "tags": ["laravel", "logs", "security", "errors"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Login Failures Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(laravel_login_failed_total[5m])",
          "legendFormat": "Login Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "drawStyle": "bars", "fillOpacity": 70, "lineWidth": 0, "barAlignment": 0 }
        }
      }
    },
    {
      "id": 2,
      "title": "Log Count by Severity",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level_name) (count_over_time({job=\"laravel_app\"} | json | __error__ = \"\" [1h]))",
          "legendFormat": "{{level_name}}",
          "refId": "A"
        }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } },
      "fieldConfig": {
        "overrides": [
          { "matcher": { "id": "byName", "options": "DEBUG" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "light-blue" } }] },
          { "matcher": { "id": "byName", "options": "INFO" },     "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" },  "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] },
          { "matcher": { "id": "byName", "options": "ERROR" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] }
        ]
      }
    },
    {
      "id": 3,
      "title": "Validation Errors (Live Stream)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | __error__ = \"\" | message =~ \"ValidationException|The .* field\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "exact" }
    },
    {
      "id": 4,
      "title": "Error & Critical Logs (Live Stream)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | __error__ = \"\" | level_name =~ \"ERROR|CRITICAL\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true }
    },
    {
      "id": 5,
      "title": "Total Errors (last 5m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(laravel_http_errors_total[5m])) or vector(0)",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        }
      }
    },
    {
      "id": 6,
      "title": "Login Failures (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(laravel_login_failed_total[1h])) or vector(0)",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        }
      }
    },
    {
      "id": 7,
      "title": "Orders Created (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(laravel_orders_created_total) or vector(0)",
          "legendFormat": "Orders",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 9,
      "title": "Validation Errors (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(laravel_validation_errors_total) or vector(0)",
          "legendFormat": "Validation Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      }
    },
    {
      "id": 8,
      "title": "All Logs (Full Stream)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | __error__ = \"\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": false, "enableLogDetails": true, "prettifyLogMessage": true }
    },
    {
      "id": 10,
      "title": "Logs Filtered by trace_id (use variable)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"laravel_app\"} | json | __error__ = \"\" | trace_id =~ \"$trace_id\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "trace_id",
        "type": "textbox",
        "label": "Trace ID",
        "current": { "value": ".*" },
        "options": [{ "value": ".*", "text": ".*" }]
      }
    ]
  }
}

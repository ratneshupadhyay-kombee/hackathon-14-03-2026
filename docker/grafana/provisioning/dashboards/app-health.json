{
  "id": null,
  "uid": "laravel-app-health",
  "title": "Laravel - Application Health",
  "tags": ["laravel", "application", "health"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Requests Per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(laravel_http_requests_total[1m])) * 60",
          "legendFormat": "Requests/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "options": { "tooltip": { "mode": "single" } }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(laravel_http_errors_total[5m])) / sum(rate(laravel_http_requests_total[5m])) * 100",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "P95 Response Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(laravel_http_response_time_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 Latency",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Top 10 Slowest Endpoints",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum by (endpoint) (rate(laravel_http_response_time_seconds_sum[5m])) / sum by (endpoint) (rate(laravel_http_response_time_seconds_count[5m])))",
          "legendFormat": "{{endpoint}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Avg Response Time" },
              { "id": "custom.width", "value": 180 }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Avg Response Time", "desc": true }] }
    },
    {
      "id": 5,
      "title": "Orders Created (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(laravel_orders_created_total[1h])",
          "legendFormat": "Orders",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 6,
      "title": "Login Failures (last 1h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(laravel_login_failed_total[1h])",
          "legendFormat": "Failures",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "HTTP Status Code Breakdown",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (increase(laravel_http_requests_total[1h]))",
          "legendFormat": "HTTP {{status}}",
          "refId": "A"
        }
      ],
      "options": { "pieType": "donut", "legend": { "displayMode": "table", "placement": "right" } }
    },
    {
      "id": 8,
      "title": "Observability Test Suite",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "title": "Test Scenarios Links",
      "type": "text",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 23 },
      "options": {
        "mode": "html",
        "content": "<div style='display: flex; gap: 20px; justify-content: center; font-size: 16px;'>\n  <a href='/test-observability/slow' target='_blank' style='color: #ffa500; font-weight: bold;'>⚡ Trigger SLOW (+3s)</a>\n  <a href='/test-observability/error' target='_blank' style='color: #ff4d4d; font-weight: bold;'>⚠️ Trigger RANDOM ERROR</a>\n  <a href='/test-observability/db-load' target='_blank' style='color: #4da6ff; font-weight: bold;'>💾 Trigger DB N+1</a>\n  <a href='/test-observability/heavy' target='_blank' style='color: #cc66ff; font-weight: bold;'>🐘 Trigger HEAVY PAYLOAD</a>\n</div>"
      }
    },
    {
      "id": 10,
      "title": "Test Suite Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(laravel_http_requests_total{endpoint=~\"test-observability/.*\"}[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
    },
    {
      "id": 11,
      "title": "Latency per Scenario",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(laravel_http_response_time_seconds_sum{endpoint=~\"test-observability/.*\"}[5m])) / sum by (endpoint) (rate(laravel_http_response_time_seconds_count{endpoint=~\"test-observability/.*\"}[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
